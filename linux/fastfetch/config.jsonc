{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

  "logo": {
    "type": "kitty",
    "source": "$HOME/Pictures/fastfetch_imgs/*.png",
    "position": "left",
    "height": 26,
    "padding": {
      "top": 1,
      "right": 1
    },
    "printRemaining": true
  },

  "display": {
    "pipe": false,
    "showErrors": false,
    "disableLinewrap": false,
    "separator": "  ",
    "color": {
      "keys": "252",
      "title": "195",
      "separator": "59",
      "output": "252"
    },
    "brightColor": true,
    "key": {
      "type": "string",
      "width": 0,
      "paddingLeft": 0
    },
    "bar": {
      "width": 16,
      "char": {
        "elapsed": "█",
        "total": "░"
      },
      "border": null,
      "color": {
        "elapsed": "118",
        "total": "59"
      }
    },
    "percent": {
      "type": ["bar", "num"],
      "ndigits": 0,
      "color": {
        "green": "118",
        "yellow": "178",
        "red": "196"
      }
    },
    "temp": {
      "unit": "C",
      "ndigits": 1,
      "color": {
        "green": "118",
        "yellow": "178",
        "red": "196"
      }
    }
  },

  "general": {
    "detectVersion": true,
    "processingTimeout": 3000,
    "thread": true
  },

  "modules": [
    {
      "type": "title",
      "key": " {#@118}󱄅 ",
      "fqdn": false,
      "color": {
        "user": "118",
        "at": "59",
        "host": "195"
      }
    },
    {
      "type": "custom",
      "format": " {#@88}╭──── {#@118}󰣇  SYSTEM {#@88}────────────────────────────────────────╮"
    },
    {
      "type": "command",
      "key": " {#@88}│ {#@118}󰇄 {#@141}Host      ",
      "text": "hostnamectl --static",
      "format": "{result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "os",
      "key": " {#@88}│ {#@118}󰣇 {#@141}OS        ",
      "format": "{?pretty-name}{pretty-name}{?}{/pretty-name}{name}{/} [{arch}] {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "kernel",
      "key": " {#@88}│ {#@118} {#@141}Kernel    ",
      "format": "{release} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│ {#@118}󰅐 {#@141}Uptime    ",
      "text": "awk '{s=int($1); d=int(s/86400); h=int((s%86400)/3600); m=int((s%3600)/60); t=sprintf(\"%02dd %02dh %02dm\", d, h, m); printf \"%s\", t}' /proc/uptime",
      "format": "{result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "custom",
      "format": " {#@88}├──── {#@81}󱂬  DESKTOP {#@88}───────────────────────────────────────┤"
    },
    {
      "type": "wm",
      "key": " {#@88}│ {#@81}󱂬 {#@208}WM        ",
      "detectPlugin": true,
      "format": "{pretty-name}{?version} ({version}){?} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "shell",
      "key": " {#@88}│ {#@81}󰞷 {#@208}Shell     ",
      "format": "{pretty-name}{?version} {version}{?} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "terminal",
      "key": " {#@88}│ {#@81} {#@208}Terminal  ",
      "format": "{pretty-name}{?version} {version}{?} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "terminalfont",
      "key": " {#@88}│ {#@81} {#@208}Font      ",
      "format": "{name}{?size} ({size}){?} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "theme",
      "key": " {#@88}│ {#@81}󰏘 {#@208}Theme    ",
      "format": "{theme1}{?theme2} ({theme2}){?} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "icons",
      "key": " {#@88}│ {#@81}󰀻 {#@208}Icons    ",
      "format": "{icons1}{?icons2} ({icons2}){?} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "cursor",
      "key": " {#@88}│ {#@81}󰳽 {#@208}Cursor    ",
      "format": "{theme}{?size} ({size}){?} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "custom",
      "format": " {#@88}├──── {#@178}󰍹  RESOURCES {#@88}─────────────────────────────────────┤"
    },
    {
      "type": "cpu",
      "key": " {#@88}│ {#@178} {#@69}CPU       ",
      "temp": false,
      "showPeCoreCount": false,
      "format": "{name} {#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│   {#@59}└─{#@111}Usage   ",
      "text": "read _ u n s i io irq sirq st g gn < /proc/stat; t1=$((u+n+s+i+io+irq+sirq+st)); id1=$((i+io)); sleep 0.15; read _ u n s i io irq sirq st g gn < /proc/stat; t2=$((u+n+s+i+io+irq+sirq+st)); id2=$((i+io)); dt=$((t2-t1)); did=$((id2-id1)); [ \"$dt\" -le 0 ] && dt=1; p=$((100*(dt-did)/dt)); [ \"$p\" -lt 0 ] && p=0; [ \"$p\" -gt 100 ] && p=100; awk -v p=\"$p\" 'BEGIN {w=16; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"█\" : \"░\"); lbl=sprintf(\"%03d%%\", p); lblc=sprintf(\"\\033[48;5;59m%s\\033[49m\", lbl); s=int((w-length(lbl))/2)+1; print substr(bar,1,s-1) lblc substr(bar,s+length(lbl));}'",
      "format": "          {#@59}•{#@252}{#@59}•{#@252} {#@214}󰣙{#@252}  {result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "gpu",
      "key": " {#@88}│ {#@178}󰢮 {#@69}GPU       ",
      "temp": true,
      "driverSpecific": true,
      "detectionMethod": "pci",
      "hideType": "integrated",
      "format": "{name}{?type} [{type}]{?} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│   {#@59}└─{#@111}Usage    ",
      "text": "if command -v nvidia-smi >/dev/null 2>&1; then u=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null | head -n1); elif [ -r /sys/class/drm/card0/device/gpu_busy_percent ]; then u=$(cat /sys/class/drm/card0/device/gpu_busy_percent 2>/dev/null); else u=''; fi; case \"$u\" in ''|*[!0-9]*) printf '░░░░░░░░░░░░░░░░'; exit 0;; esac; [ \"$u\" -lt 0 ] && u=0; [ \"$u\" -gt 100 ] && u=100; awk -v p=\"$u\" 'BEGIN {w=16; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"█\" : \"░\"); lbl=sprintf(\"%03d%%\", p); lblc=sprintf(\"\\033[48;5;59m%s\\033[49m\", lbl); s=int((w-length(lbl))/2)+1; print substr(bar,1,s-1) lblc substr(bar,s+length(lbl));}'",
      "format": "         {#@59}•{#@252}{#@59}•{#@252} {#@45}󱚢{#@252}  {result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│ {#@178}󰍛 {#@69}RAM       ",
      "text": "awk '/MemTotal:/ {t=$2} /MemAvailable:/ {a=$2} END {if (t > 0) printf \"%.2f GiB/%.2f GiB\", a/1048576, t/1048576; else printf \"n/a\"}' /proc/meminfo",
      "format": "{result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│   {#@59}└─{#@111}Usage    ",
      "text": "awk '/MemTotal:/ {t=$2} /MemAvailable:/ {a=$2} END {if (t <= 0) {print \"n/a\"; exit} u=t-a; p=int((u*100)/t + 0.5); if (p < 0) p=0; if (p > 100) p=100; w=16; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"█\" : \"░\"); lbl=sprintf(\"%03d%%\", p); lblc=sprintf(\"\\033[48;5;59m%s\\033[49m\", lbl); s=int((w-length(lbl))/2)+1; bar=substr(bar,1,s-1) lblc substr(bar,s+length(lbl)); print bar}' /proc/meminfo",
      "format": "         {#@59}•{#@252}{#@59}•{#@252} {#@199}󱃄{#@252}  {result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│ {#@178}󰍹 {#@69}Display   ",
      "splitLines": true,
      "text": "if command -v niri >/dev/null 2>&1; then niri msg outputs | awk '/^Output \"/ {line=$0; sub(/^Output \"/, \"\", line); sub(/\" \\([^)]+\\)$/, \"\", line); name=line; n=split(name, a, \" \" ); last=a[n]; if (last ~ /[A-Za-z]/ && last ~ /[0-9]/ && length(last) >= 5) name=substr(name, 1, length(name)-length(last)-1); if (!(name in counts)) order[++orderCount]=name; counts[name]++} END {if (orderCount == 0) print \"n/a\"; for (i=1; i<=orderCount; i++) {name=order[i]; if (counts[name] > 1) printf \"%s (x%d)\\n\", name, counts[name]; else print name}}'; else printf 'n/a'; fi",
      "format": "{result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│   {#@59}└─{#@111}Settings  ",
      "splitLines": true,
      "text": "if command -v niri >/dev/null 2>&1; then niri msg outputs | awk '/^Output \"/ {out=$0; sub(/^.*\\(/, \"\", out); sub(/\\).*$/, \"\", out); next} /^  Current mode:/ {mode=$0; sub(/^  Current mode: /, \"\", mode); sub(/ Hz$/, \"Hz\", mode); printf \"(%s): %s\\n\", out, mode }'; else printf 'n/a'; fi",
      "format": "{result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│ {#@178}󰋊 {#@69}Main      ",
      "text": "df -T / 2>/dev/null | awk 'NR==2 {n=split($1,a,\"/\"); dev=a[n]; fs=$2; t=$3; u=$4; if (dev ~ /^luks-/) { cmd=\"ls /sys/class/block/$(basename $(readlink /dev/mapper/\" dev \"))/slaves/ 2>/dev/null | head -n1\"; cmd | getline dev; close(cmd) } if (t<=0) {print \"n/a\"; exit} printf \"%s %.2f GiB/%.2f GiB [%s]\", dev, u/1048576, t/1048576, fs}'",
      "format": "{result}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│   {#@59}└─{#@111}Usage    ",
      "text": "df -B1 / 2>/dev/null | awk 'NR==2 {t=$2; u=$3; if (t<=0) {print \"n/a\"; exit} p=int((u*100)/t + 0.5); if (p<0)p=0; if (p>100)p=100; w=16; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"█\" : \"░\"); lbl=sprintf(\"%03d%%\", p); lblc=sprintf(\"\\033[48;5;59m%s\\033[49m\", lbl); s=int((w-length(lbl))/2)+1; print substr(bar,1,s-1) lblc substr(bar,s+length(lbl))}'",
      "format": "         {#@59}•{#@252}{#@59}•{#@252} {#@226}󰋊{#@252}  {result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│ {#@178}󰋊 {#@69}Data      ",
      "text": "if [ -e /mnt/data ]; then df -T /mnt/data 2>/dev/null | awk 'NR>1 && $2==\"ext4\" {n=split($1,a,\"/\"); dev=a[n]; fs=$2; t=$3; u=$4; if (t<=0) {print \"n/a\"; exit} printf \"%s %.2f GiB/%.2f GiB [%s]\", dev, u/1048576, t/1048576, fs; exit}'; else printf 'n/a'; fi",
      "format": "{result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "command",
      "key": " {#@88}│   {#@59}└─{#@111}Usage    ",
      "text": "if [ -e /mnt/data ]; then df -B1 -T /mnt/data 2>/dev/null | awk 'NR>1 && $2==\"ext4\" {t=$3; u=$4; if (t<=0) {print \"n/a\"; exit} p=int((u*100)/t + 0.5); if (p<0)p=0; if (p>100)p=100; w=16; f=int(p*w/100); bar=\"\"; for (i=1; i<=w; i++) bar=bar ((i<=f) ? \"█\" : \"░\"); lbl=sprintf(\"%03d%%\", p); lblc=sprintf(\"\\033[48;5;59m%s\\033[49m\", lbl); s=int((w-length(lbl))/2)+1; print substr(bar,1,s-1) lblc substr(bar,s+length(lbl)); exit}'; else printf 'n/a'; fi",
      "format": "         {#@59}•{#@252}{#@59}•{#@252} {#@51}󰋊{#@252}  {result} {#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@59}•{#@252}{#@88}│"
    },
    {
      "type": "custom",
